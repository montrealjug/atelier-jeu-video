code = "shader_type canvas_item;
render_mode blend_mix;

uniform vec4 flash_color : source_color;
uniform float flash_value : hint_range(0.0, 1.0);



void fragment() {
// ColorParameter:2
	vec4 n_out2p0 = flash_color;


// FloatParameter:4
	float n_out4p0 = flash_value;


// VectorOp:5
	vec3 n_out5p0 = vec3(n_out2p0.xyz) * vec3(n_out4p0);


// Input:7
	vec4 n_out7p0 = COLOR;


// VectorOp:6
	vec3 n_out6p0 = n_out5p0 + vec3(n_out7p0.xyz);


// Output:0
	COLOR.rgb = n_out6p0;


}
"
